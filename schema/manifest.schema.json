{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ThemeManifest",
  "type": "object",
  "required": ["schemaVersion", "id", "name", "rootClassName", "cssVars"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,30}$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "author": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "github": { "type": "string" }
      }
    },
    "license": { "type": "string" },
    "compatibility": {
      "type": "object",
      "properties": {
        "zenbuSite": { "type": "string" }
      }
    },
    "coverImage": { "type": "string" },
    "previewImage": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "rootClassName": { "type": "string", "pattern": "^[a-z][a-z0-9-]*-root$" },
    "cssVars": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "label", "type", "default"],
        "properties": {
          "key": { "type": "string", "pattern": "^--[a-z][a-z0-9-]*$" },
          "label": { "type": "string" },
          "type": { "type": "string", "enum": ["color-hex", "color-rgb-triplet", "length", "number", "string"] },
          "default": { "type": "string" },
          "pairedWith": { "type": "string" },
          "affects": { "type": "array", "items": { "type": "string" } },
          "hint": { "type": "string" }
        }
      }
    },
    "semantics": { "type": "object" },
    "blockTypesUsed": { "type": "array", "items": { "type": "string" } },
    "samplePages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug", "path"],
        "properties": {
          "slug": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    }
  }
}
